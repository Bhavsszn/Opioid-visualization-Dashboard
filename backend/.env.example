# backend/.env.example
# Put real values in backend/.env locally (do not commit it)

# Census / population (rotate if previously committed)
CENSUS_API_KEY=YOUR_CENSUS_KEY_HERE

# Data pull settings
WONDER_START_YEAR=2018
WONDER_END_YEAR=2023

# Paths
DATA_DIR=../data
DB_PATH=../data/opioid.db
STATIC_API_DIR=../frontend/public/api

# App environment
APP_ENV=dev

# CORS
# Comma-separated origins, or * for any origin (recommended only for local dev)
CORS_ORIGINS=*

# Forecast defaults
DEFAULT_FORECAST_HORIZON=3
