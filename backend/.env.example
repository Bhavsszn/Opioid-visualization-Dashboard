# backend/.env.example
# Copy to backend/.env and edit values for your environment.

# Runtime environment
ENVIRONMENT=dev

# API behavior
DEFAULT_FORECAST_HORIZON=3
ALLOWED_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
SLOW_REQUEST_MS=750

# Database backend selection: postgres | sqlite
DB_BACKEND=sqlite
ENABLE_SQLITE_FALLBACK=true
ENABLE_STATIC_FALLBACK=true

# Legacy local data paths (used when DB_BACKEND=sqlite)
DATA_DIR=../data
DB_PATH=../data/opioid.db
STATIC_API_DIR=../frontend/public/api

# PostgreSQL serving layer (used when DB_BACKEND=postgres)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=opioid
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_SCHEMA=analytics
POSTGRES_SSLMODE=prefer
# Optional full DSN override
# DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# Optional Databricks SQL Warehouse connectivity (for sync script)
DATABRICKS_HOST=
DATABRICKS_HTTP_PATH=
DATABRICKS_TOKEN=
