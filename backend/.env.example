# Backend runtime
ENVIRONMENT=dev
DB_BACKEND=postgres

# PostgreSQL serving connection
# Prefer DATABASE_URL in local/dev to avoid splitting credentials across variables.
# Example:
# DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require
DATABASE_URL=
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=opioid
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_SCHEMA=analytics
POSTGRES_SSLMODE=prefer

# Runtime behavior toggles (keep disabled for Postgres-first runtime)
ENABLE_SQLITE_FALLBACK=false
ENABLE_STATIC_FALLBACK=false

# API settings
DEFAULT_FORECAST_HORIZON=3
ALLOWED_CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
SLOW_REQUEST_MS=750

# Optional local paths used by utility scripts
DATA_DIR=../data
DB_PATH=../data/opioid.db
STATIC_API_DIR=../frontend/public/api

# Optional Databricks variables (used by sync scripts)
DATABRICKS_HOST=
DATABRICKS_HTTP_PATH=
DATABRICKS_TOKEN=
