# backend/.env.example
# Copy to backend/.env and edit values for your environment.

# Runtime environment
ENVIRONMENT=dev

# API behavior
DEFAULT_FORECAST_HORIZON=3
ALLOWED_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
SLOW_REQUEST_MS=750

# Database backend (PostgreSQL only)
DB_BACKEND=postgres
DATABASE_URL=postgresql://neondb_owner:npg_3lpZ6TCJPAmB@ep-silent-hall-a4jqxmf3-pooler.us-east-1.aws.neon.tech:5432/neondb?sslmode=require
POSTGRES_SCHEMA=analytics
ALLOWED_CORS_ORIGINS=["http://127.0.0.1:5173","http://localhost:5173"]

# PostgreSQL serving layer (used when DB_BACKEND=postgres)
POSTGRES_HOST=ep-silent-hall-a4jqxmf3-pooler.us-east-1.aws.neon.tech
POSTGRES_PORT=5432
POSTGRES_DB=neondb
POSTGRES_USER=neondb_owner
POSTGRES_PASSWORD=npg_3lpZ6TCJPAmB
POSTGRES_SCHEMA=analytics
POSTGRES_SSLMODE=require
# Optional full DSN override
# DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=prefer

# Optional Databricks SQL Warehouse connectivity (for sync script)
DATABRICKS_HOST=
DATABRICKS_HTTP_PATH=
DATABRICKS_TOKEN=
