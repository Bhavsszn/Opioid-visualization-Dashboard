# frontend/.env.example
# Local dev API (FastAPI)
VITE_API_BASE=http://127.0.0.1:8000

# Static mode (reads from /public/api/*.json)
# true for Netlify/GitHub Pages demos, false for backend API
VITE_USE_STATIC=true

# Optional: embed a published Power BI dashboard in the /powerbi route
# Example: https://app.powerbi.com/view?r=...
VITE_POWERBI_EMBED_URL=
